{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitrospeech"],
  "ios": {
    "iosModuleName": "NitroSpeech"
  },
  "android": {
    "androidNamespace": ["nitrospeech"],
    "androidCxxLibName": "NitroSpeech"
  },
  "autolinking": {
    "NitroSpeech": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroSpeech"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroSpeech"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ],
  "gitAttributesGeneratedFlag": false
}
