{
  "name": "@gmessier/nitro-speech",
  "version": "0.4.0",
  "description": "React Native Real-time Speech Recognition Library powered by Nitro Modules",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "app.plugin.js",
    "nitro.json",
    "*.podspec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf lib && rm -f tsconfig.tsbuildinfo && bun tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "nitro": "rm -rf nitrogen && npx nitrogen@latest",
    "localnitro": "rm -rf nitrogen && node ../../../nitro/nitro/packages/nitrogen/lib/index.js"
  },
  "keywords": [
    "react-native",
    "speech",
    "recognition",
    "speech-recognition",
    "speech-to-text",
    "SpeechAnalyzer",
    "SpeechTranscriber",
    "DictationTranscriber",
    "stt",
    "voice",
    "voice-recognition",
    "transcription",
    "transcriber",
    "audio",
    "microphone",
    "nitro",
    "nitro-modules"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NotGeorgeMessier/nitro-speech.git"
  },
  "bugs": {
    "url": "https://github.com/NotGeorgeMessier/nitro-speech/issues"
  },
  "author": "George Messier",
  "homepage": "https://github.com/NotGeorgeMessier/nitro-speech#readme",
  "license": "MIT",
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "0.84.1",
    "@types/react": "19.2.14",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-nitro-modules": "0.35.6",
    "nitrogen": "0.35.6",
    "react-native-builder-bob": "0.37.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
